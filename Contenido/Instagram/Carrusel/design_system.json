{
  "design_system": {
    "metadata": {
      "source": "Ryventis IA + Content Creators",
      "analyzed_images": 15,
      "creation_date": "2025-04-23"
    },
    "color_palette": {
      "primary": {
        "name": "Rust / Burnt Orange",
        "hex": "#C97855",
        "rgb": "rgb(201, 120, 85)",
        "usage": "Call-to-action boxes, highlights, badges, accent bars"
      },
      "secondary": {
        "name": "Dark Charcoal",
        "hex": "#0A0A0F",
        "rgb": "rgb(10, 10, 15)",
        "usage": "Background, text, main container"
      },
      "tertiary": {
        "name": "Off-White / Cream",
        "hex": "#F5F5F0",
        "rgb": "rgb(245, 245, 240)",
        "usage": "Content backgrounds, info boxes, text areas"
      },
      "accent_light": {
        "name": "Light Beige",
        "hex": "#FFF8F0",
        "rgb": "rgb(255, 248, 240)",
        "usage": "Secondary info boxes, step containers"
      },
      "accent_grey": {
        "name": "Light Grey",
        "hex": "#E8E8E8",
        "rgb": "rgb(232, 232, 232)",
        "usage": "Borders, dividers, subtle backgrounds"
      },
      "text_dark": {
        "name": "Pure Black",
        "hex": "#000000",
        "rgb": "rgb(0, 0, 0)",
        "usage": "Primary text, headings"
      },
      "text_light": {
        "name": "White",
        "hex": "#FFFFFF",
        "rgb": "rgb(255, 255, 255)",
        "usage": "Text over dark backgrounds, contrast text in badges"
      },
      "accent_decorative": {
        "name": "Coral / Burnt Sienna",
        "hex": "#D97755",
        "rgb": "rgb(217, 119, 85)",
        "usage": "Bullet points, decorative elements, icons"
      }
    },
    "typography": {
      "headings": {
        "family": "Syne",
        "weight": 800,
        "style": "normal",
        "usage": "Main titles, section headers",
        "examples": "7 Trucos Para Reducir TOKENS DE CLAUDE"
      },
      "body": {
        "family": "DM Sans",
        "weight": "400-500",
        "style": "normal",
        "line_height": "1.5-1.6",
        "usage": "Body text, descriptions"
      },
      "code": {
        "family": "monospace",
        "weight": 400,
        "style": "normal",
        "usage": "Code snippets, terminal output"
      },
      "accent_text": {
        "family": "Syne or DM Sans",
        "weight": 600,
        "style": "normal",
        "color": "#C97855",
        "usage": "Emphasized text within paragraphs"
      }
    },
    "layout_structure": {
      "container": {
        "max_width": "100%",
        "padding": "40-60px",
        "background": "#F5F5F0 or #0A0A0F",
        "border_radius": "0px (no rounding)"
      },
      "card_spacing": {
        "vertical_gap": "20-30px",
        "horizontal_padding": "30-40px"
      },
      "badge_style": {
        "background": "#C97855",
        "color": "#FFFFFF",
        "padding": "8-12px 16-20px",
        "border_radius": "8-12px",
        "font_weight": 600,
        "display": "inline-block"
      }
    },
    "component_patterns": {
      "header_section": {
        "label_badge": {
          "background": "#000000",
          "color": "#FFFFFF",
          "padding": "6-8px 12-16px",
          "border_radius": "6-8px",
          "font_size": "12-14px",
          "font_weight": 600,
          "margin_bottom": "20px"
        }
      },
      "title_with_highlight": {
        "structure": "Text + Highlighted Box",
        "highlight_background": "#C97855",
        "highlight_color": "#FFFFFF",
        "highlight_padding": "8-12px 16-20px",
        "highlight_border_radius": "6-8px",
        "display": "inline-block within text"
      },
      "info_box": {
        "background": "#FFF8F0",
        "border_left": "4-6px solid #C97855",
        "padding": "20-24px",
        "border_radius": "0px",
        "font_size": "14-16px",
        "line_height": "1.6"
      },
      "list_item": {
        "bullet_character": "❋ or ※ (decorative star)",
        "bullet_color": "#C97855",
        "list_marker": "monospace symbol",
        "spacing_between": "12-16px"
      },
      "numbered_steps": {
        "number_background": "#C97855",
        "number_color": "#FFFFFF",
        "number_size": "24-32px",
        "number_width": "40-50px",
        "number_height": "40-50px",
        "display": "flex, centered"
      }
    },
    "visual_elements": {
      "divider": {
        "type": "horizontal line",
        "color": "#E8E8E8 or #000000",
        "thickness": "1-2px",
        "margin_vertical": "30-40px",
        "full_width": true
      },
      "decorative_star": {
        "character": "※ or ❋",
        "color": "#C97855",
        "size": "16-20px",
        "usage": "Between sections, emphasis"
      },
      "terminal_background": {
        "background": "#1A1A1F",
        "color": "#00FF00 or #FFFFFF",
        "font": "monospace",
        "padding": "20px",
        "border_radius": "8px"
      },
      "button": {
        "background": "#FFFFFF or #C97855",
        "text_color": "#000000 or #FFFFFF",
        "padding": "12-16px 24-32px",
        "border_radius": "6-8px",
        "border": "2px solid #000000",
        "font_weight": 600
      }
    },
    "spacing_system": {
      "xs": "4px",
      "sm": "8px",
      "md": "16px",
      "lg": "24px",
      "xl": "32px",
      "2xl": "40px",
      "3xl": "60px"
    },
    "typography_scale": {
      "h1": {
        "size": "48-56px",
        "weight": 800,
        "line_height": 1.2
      },
      "h2": {
        "size": "36-44px",
        "weight": 800,
        "line_height": 1.3
      },
      "h3": {
        "size": "28-32px",
        "weight": 700,
        "line_height": 1.4
      },
      "body": {
        "size": "16-18px",
        "weight": 400,
        "line_height": 1.5
      },
      "small": {
        "size": "12-14px",
        "weight": 400,
        "line_height": 1.4
      }
    },
    "visual_language": {
      "aesthetic": "Modern Minimalist + Educational",
      "mood": "Professional, Clean, Approachable",
      "contrast": "High contrast between dark and light sections",
      "alignment": "Left-aligned text, centered badges/boxes",
      "emphasis_technique": "Color blocking with rust orange",
      "icon_style": "Monospace characters, decorative symbols",
      "grid_system": "Loose grid, whitespace-heavy"
    },
    "ryventis_specific": {
      "brand_colors": {
        "dark_bg": "#0A0A0F",
        "accent_teal": "#00E5CC",
        "accent_purple": "#7C3AED",
        "primary_orange": "#C97855"
      },
      "brand_fonts": {
        "headings": "Syne 800",
        "body": "DM Sans"
      },
      "brand_style": "Tech-forward, minimalist, approachable to SMEs"
    },
    "content_patterns": {
      "post_structure": [
        "Badge/Label (top left)",
        "Title with inline highlight box",
        "Divider line",
        "Description text or intro",
        "Multiple info boxes with borders",
        "Decorative divider",
        "Author/credit (bottom)"
      ],
      "color_organization": {
        "rust_orange": "Primary actions, highlights, emphasis",
        "light_beige": "Secondary information, supporting content",
        "dark_charcoal": "Text, backgrounds, contrast",
        "white": "High contrast text, clarity"
      }
    },
    "responsive_behavior": {
      "mobile_first": true,
      "padding_mobile": "20-24px",
      "padding_desktop": "40-60px",
      "font_scaling": "Responsive, maintains hierarchy"
    }
  }
}
